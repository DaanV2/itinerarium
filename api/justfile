# Task runner for Itinerarium. Run `just` to list recipes.
# Requires: go, node/npm, golangci-lint, and (optionally) docker.

set windows-shell := ["cmd.exe", "/c"]

# Show available recipes
default:
    @just --list

# --- API (Go, from api/) ---

# Start the API server on :8080
api:
    go run . serve

# Format Go code
fmt:
    gofmt -w .

# Compile all Go packages
build:
    go build ./...

# Run go vet
vet:
    go vet ./...

# Run golangci-lint (same config as CI)
lint:
    golangci-lint run ./...

# Run all Go tests
test:
    go test ./... --cover -coverprofile=reports/coverage.out --covermode atomic --coverpkg=./...
    go tool cover -html=reports/coverage.out

# Everything the API CI job checks
verify: build vet lint test

